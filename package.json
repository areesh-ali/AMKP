{
  "name": "amkp",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev:api": "pnpm --filter @amkp/api dev",
    "dev:worker": "pnpm --filter @amkp/worker dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm --filter @amkp/application test && pnpm --filter @amkp/adapters-providers test && pnpm --filter @amkp/openapi test && pnpm --filter @amkp/api test",
    "test:auth": "pnpm --filter @amkp/api test",
    "typecheck": "pnpm -r run typecheck",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  }
}
