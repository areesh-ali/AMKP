PORT=3000
DATABASE_URL=postgresql://amkp:amkp@localhost:5433/amkp
REDIS_URL=redis://localhost:6379
NODE_ENV=development
PLATFORM_ADMIN_TOKEN=dev-admin-token-change-me
# AMKP_API_KEY_PEPPER=change-me-in-prod   # HMAC pepper for API key hashes
# AMKP_JOB_QUEUE=memory          # force in-process queue (tests)
# AMKP_VECTOR_INDEX=memory       # force in-process index (default: postgres+pgvector)
# Trace/audit/cache also use memory when AMKP_JOB_QUEUE=memory or NODE_ENV=test
# AMKP_OBJECT_STORAGE_DIR=./.data/objects  # off-DB document bytes (local FS)
# AMKP_S3_BUCKET=amkp-docs                 # S3/MinIO/R2 (wins over local FS)
# AMKP_S3_REGION=us-east-1
# AMKP_S3_ENDPOINT=http://127.0.0.1:9000   # MinIO / custom
# AMKP_S3_FORCE_PATH_STYLE=1
# AMKP_S3_ACCESS_KEY_ID=
# AMKP_S3_SECRET_ACCESS_KEY=
# AMKP_S3_KEY_PREFIX=dev
# AMKP_EMBEDDING_API_KEY=           # OpenAI-compatible embeddings (else stub)
# AMKP_EMBEDDING_MODEL=text-embedding-3-small
# AMKP_EMBEDDING_BASE_URL=https://api.openai.com/v1
# AMKP_EMBEDDING_DIMS=64            # must match pgvector column (64)
# AMKP_RATE_LIMIT_PER_MINUTE=120    # per-Tenant retrieve/MCP limit (0 = off)
# AMKP_CORS_ORIGINS=http://localhost:5173,http://localhost:3001
# AMKP_HSTS=1                              # send Strict-Transport-Security (HTTPS terminators)
# AMKP_HSTS_MAX_AGE=31536000
# AMKP_DOCUMENT_WEBHOOK_URL=https://hooks.example/amkp  # POST on document parsed
# AMKP_DOCUMENT_WEBHOOK_SECRET=whsec_...                # HMAC-SHA256 for X-AMKP-Signature
# AMKP_PAGE_VISION_URL=https://vlm.example/ocr  # HTTP page-vision vendor for tier3
# AMKP_PAGE_VISION_SPEND_USD=0.02
# AMKP_EVAL_JUDGE_URL=https://judge.example/v1/eval  # HTTP judge for golden-set llm mode
# AMKP_EVAL_JUDGE_MODEL=http-eval-judge
# AMKP_PDF_ENGINE=cheap                 # force regex FlateDecode PDF path (default: unpdf/PDF.js)
# AMKP_ACCESS_LOG=1                      # JSON access log per request
# AMKP_TRACE_CONSOLE=1                 # log retrieve spans to console
# AMKP_OTEL=1                          # enable OTel API tracer (default OTLP http://127.0.0.1:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=amkp-api
# WORKER_HEALTH_PORT=3001
# AMKP_BODY_LIMIT=25mb                 # JSON body limit for ingest base64
# AMKP_REQUEST_TIMEOUT_MS=30000        # soft 504 if response not finished
# AMKP_MAX_DOCUMENT_BYTES=10485760     # decoded ingest size cap (10 MiB)
# AMKP_DOCUMENT_VERSION_RETENTION=10  # keep newest N versions per sourceKey (auto-prune on ingest)
# AMKP_IDEMPOTENCY_TTL_SECONDS=86400  # Idempotency-Key cache TTL for ingest
# AMKP_ALLOWED_CONTENT_TYPES=text/plain,text/markdown,application/pdf
# AMKP_MAX_QUERY_CHARS=4000            # retrieve query length cap
