generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  tenants   Tenant[]

  @@map("accounts")
}

model Tenant {
  id                String     @id
  accountId         String     @map("account_id")
  name              String
  agenticEnabled    Boolean    @default(false) @map("agentic_enabled")
  pageVisionEnabled Boolean    @default(false) @map("page_vision_enabled")
  vectorNamespace   String     @unique @map("vector_namespace")
  createdAt         DateTime   @default(now()) @map("created_at")
  account           Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  apiKeys           ApiKey[]
  documents         Document[]

  @@index([accountId])
  @@map("tenants")
}

model Document {
  id          String   @id
  tenantId    String   @map("tenant_id")
  sourceKey   String   @map("source_key")
  version     Int
  contentHash String   @map("content_hash")
  filename    String
  contentType String   @map("content_type")
  byteSize    Int      @map("byte_size")
  content     Bytes
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks      Chunk[]

  @@unique([tenantId, sourceKey, version])
  @@index([tenantId])
  @@index([tenantId, sourceKey])
  @@map("documents")
}

model Chunk {
  id                String   @id
  tenantId          String   @map("tenant_id")
  documentId        String   @map("document_id")
  documentVersionId String   @map("document_version_id")
  content           String
  parseTier         String   @map("parse_tier")
  parseConfidence   Float    @map("parse_confidence")
  ordinal           Int
  tableJson         Json?    @map("table_json")
  createdAt         DateTime @default(now()) @map("created_at")
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId])
  @@map("chunks")
}

model ApiKey {
  id         String    @id
  tenantId   String    @map("tenant_id")
  keyHash    String    @map("key_hash")
  prefix     String
  createdAt  DateTime  @default(now()) @map("created_at")
  revokedAt  DateTime? @map("revoked_at")
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([keyHash])
  @@map("api_keys")
}
