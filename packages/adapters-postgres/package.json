{
  "name": "@amkp/adapters-postgres",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"lint: stub\"",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@amkp/application": "workspace:*",
    "@amkp/domain": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "^8.16.3",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.4",
    "prisma": "7.8.0",
    "typescript": "5.8.3",
    "vitest": "^3.2.4"
  }
}
